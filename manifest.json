{
  "manifest_version": 3,
  "name": "Web Focus Tracker",
  "version": "2.0.0",
  "description": "Track time spent on websites with day, average and all-time insights.",
  "permissions": ["tabs", "storage", "alarms", "idle", "identity"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://www.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "47184503589-72sa3gsmjv1e11f2kn0528obe9htalmk.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile",
      "https://www.googleapis.com/auth/datastore"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Tracker"
  }
}
